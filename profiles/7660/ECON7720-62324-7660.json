        },
        {
            "number": "LO2.",
            "description": "Critically apply microeconomic concepts and evaluation techniques across a range of environmental issues."
        },
        {
            "number": "LO3.",
            "description": "Critically assess environmental policy and management mechanisms conceptually."
        },
        {
            "number": "LO4.",
