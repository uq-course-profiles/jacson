        {
            "number": "LO1.",
            "description": "Name and describe the major elements of the international finance"
        },
        {
            "number": "LO2.",
            "description": "Understand the key determinants of current account movements and nominal/real exchange rates"
        },
        {
            "number": "LO3.",
            "description": "Discuss the structure of the international finance and trade framework and the role of the various national and supra-national institutions that constitute the system"
        },
        {
            "number": "LO4.",
            "description": "Assess the benefits and limits of the major economic tools and models in providing answers or solutions to questions or problems emerging from cross-national economic activity"
        }
    ],
