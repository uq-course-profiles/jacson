    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Have a foundational understanding of research and theory in developmental, clinical, and social psychology, and their broad historical contexts"
        },
        {
            "number": "LO2.",
            "description": "Engage in scientific thinking to accurately interpret and meaningfully progress research in the field"
        },
        {
            "number": "LO3.",
            "description": "Use the language of psychology to engage in oral and written communication of research in the field"
        },
        {
            "number": "LO4.",
            "description": "Communicate and work effectively with others from diverse backgrounds to achieve a common outcome"
        },
        {
            "number": "LO5.",
            "description": "Become active participants in academic culture and practices at the university level"
        },
        {
            "number": "LO6.",
            "description": "Describe Aboriginal and Torres Strait Islander peoples identities, cultures, and histories with particular focus on connection to Country, cultural resilience, and resistance to colonisation."
        }
