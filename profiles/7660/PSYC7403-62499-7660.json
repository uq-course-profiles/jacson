    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Identify the psychological factors influencing the effectiveness of individuals, teams, and organisations in relation to productivity, safety, and well-being."
        },
        {
            "number": "LO2.",
            "description": "Evaluate and diagnose real organisational problems."
        },
        {
            "number": "LO3.",
            "description": "Select and apply evidence-based interventions to enhance productivity, safety, and well-being in diverse business environments."
        },
        {
            "number": "LO4.",
            "description": "Communicate evidence-based arguments and recommendations for enhancing productivity, safely, and well-being to a business audience."
        },
        {
            "number": "LO5.",
            "description": "Demonstrate teamwork behaviours to resolve complex, real-world challenges in the field of business psychology."
        }
    ],
    "assessments": [
        {
            "assessment_detail_section_id": "assessment-detail-0",
            "assessment_title": "Case study analysis",
            "special_indicators": [
                {
                    "special_indicators_class": "icon--how-youll-learn--multiple-circle icon-text--small",
                    "special_indicator_text": "Team or group-based"
