            "number": "LO1.",
            "description": "Model dynamic macroeconomic phenomena using modern analytical tools."
        },
        {
            "number": "LO2.",
            "description": "Rigorously analyse a number of salient macroeconomic issues, both in the long-run and in the short-run."
        },
        {
            "number": "LO3.",
            "description": "Evaluate the proper role of the government in the face of macroeconomic challenges."
        },
        {
            "number": "LO4.",
            "description": "Analyse macroeconomic data from Australia and the rest of the world."
        },
        {
            "number": "LO5.",
            "description": "Assess the link between macroeconomic analysis and real-world policymaking."
        }
    ],
