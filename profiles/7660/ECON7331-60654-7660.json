    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Explain matrix algebra proficiently to derive properties of (and compute) various econometric estimators."
        },
        {
            "number": "LO2.",
            "description": "Evaluate the theory behind the General Linear Regression Model."
        },
        {
            "number": "LO3.",
            "description": "Explain the numerical and statistical properties of the OLS, GLS and IV estimators."
        },
        {
            "number": "LO4.",
            "description": "Demonstrate the finite sample and asymptotic properties of the OLS, GLS and IV estimators."
        },
        {
            "number": "LO5.",
            "description": "Use statistical packages such as R-Studio to compute the various estimators on real world datasets."
        },
        {
            "number": "LO6.",
            "description": "Examine the learned theory and methods to the real world."
        }
    ],
