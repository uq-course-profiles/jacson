    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Explain the nature of scientific data and the need for statistical analysis."
        },
        {
            "number": "LO2.",
            "description": "Identify factors related to the design of a scientific study, including sample size and power."
        },
        {
            "number": "LO3.",
            "description": "Identify and critically evaluate the role of data analysis and statistics in scientific research and publications."
        },
        {
            "number": "LO4.",
            "description": "Identify and critically evaluate ethical issues in scientific research."
        },
        {
            "number": "LO5.",
            "description": "Demonstrate a foundational knowledge of statistical methods by being able to carry out simple statistical procedures by hand."
        },
        {
            "number": "LO6.",
            "description": "Use statistical software appropriately and confidently for exploratory data analysis and to make relevant statistical conclusions."
        },
        {
            "number": "LO7.",
            "description": "Plan and carry out a research project, and analyse and communicate the results."
        }
    ],
