    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Identify prominent theories and models about human behaviour in organisations, and critically discuss their application to management."
        },
        {
            "number": "LO2.",
            "description": "Identify prominent theories and models of group functioning in organisations, and critically discuss their significance in workplaces."
        },
        {
            "number": "LO3.",
            "description": "As an individual and in groups, explain how organisations function as institutions including issues of structure, power, politics, and change."
        },
        {
            "number": "LO4.",
            "description": "Critically examine your own behaviour as a manager, and identify strategies for improving your skills in people management."
        },
        {
            "number": "LO5.",
            "description": "Reflect on the ethical and social impact of managing people within organisations."
        }
    ],
    "assessments": [
        {
            "assessment_detail_section_id": "assessment-detail-0",
            "assessment_title": "Case Analysis Presentation (Group)",
            "special_indicators": [
                {
                    "special_indicators_class": "icon--how-youll-learn--multiple-circle icon-text--small",
                    "special_indicator_text": "Team or group-based"
                },
                {
                    "special_indicators_class": "icon--how-youll-learn--multiple-circle-1 icon-text--small",
                    "special_indicator_text": "In-person"
                }
            ],
            "weighting": "<dd>30%</dd>",
            "due_date": "<dd><p>Presentation Slides - 5PM -  4/09/2026</p>\n<p>Presentation Week 7 - Week 8</p>\n<p>\n</p><p>Presentation during your allocated tutorial.</p></dd>",
            "learning_objectives": "L01, L02, L05",
            "mode": "Oral",
            "category": "Presentation",
            "task_description": "<div class=\"collapsible collapsible--text\">\n<p>In this assessment, you will work in a randomly assigned team of 4–5 students to select a real organisation facing a current problem or opportunity that has appeared in the media within the last twelve months, and deliver a 10-minute presentation analysing the issue through the lens of organisational behaviour theory.</p>\n<p>Your presentation (10–15 PowerPoint slides) must identify the organisational issue, analyse it using 2 or more OB concepts/theories from Weeks 2–6 (3 or more for a higher grade), and provide evidence-based recommendations, supported by at least 7 peer-reviewed references.</p>\n<p>One group member must submit the slides via Blackboard by the due date, and presentations are delivered during your allocated tutorial in Weeks 7–8 using brief notes only.</p>\n<p>After presenting, each member must complete a peer evaluation via BuddyCheck, which may be used to adjust individual marks.</p>\n<p>This assessment aims to demonstrate your ability to collaborate as a team to apply key OB theories to a real-world organisational challenge of your own choosing.</p>\n<p><strong>Please Note: </strong>The presentation will be recorded for marking purposes per UQ Policy.</p>\n<button class=\"collapsible__toggle\">\n<span class=\"collapsible__open link--icon icon--standard--arrow-down-1\">Read full task description</span>\n<span class=\"collapsible__close link--icon icon--standard--arrow-up-1\">Hide full task description</span>\n</button>\n</div>",
            "submission_guidelines": "<p>Submission guidelines: </p>",
            "deferral_or_extension": "<p>You may be able to <a href=\"https://my.uq.edu.au/information-and-services/manage-my-program/exams-and-assessment/applying-assessment-extension\">apply for an extension</a>.</p>",
            "late_submission": "<p>A <a href=\"https://policies.uq.edu.au/document/view-current.php?id=184\">penalty</a> of 10% of the maximum possible mark will be deducted per 24 hours from time submission is due for up to 7 days. After 7 days, you will receive a mark of 0.</p>",
            "additional_info": "<p>You may be able to <a href=\"https://my.uq.edu.au/information-and-services/manage-my-program/exams-and-assessment/applying-assessment-extension\">apply for an extension</a>.</p>"
        },
        {
            "assessment_detail_section_id": "assessment-detail-1",
            "assessment_title": "Critical Incident Reflection Essay (Individual)",
            "special_indicators": [
                {
                    "special_indicators_class": "icon--engineering-and-computing--laptop icon-text--small",
                    "special_indicator_text": "Online"
                }
            ],
            "weighting": "<dd>35%</dd>",
            "due_date": "<dd><p> 9/10/2026 5:00 pm</p></dd>",
            "learning_objectives": "L01, L03, L04, L05",
            "mode": "Written",
            "category": "Essay/ Critique, Reflection",
            "task_description": "<div class=\"collapsible collapsible--text\">\n<p>In this individual assessment, you will write a reflective essay drawing on your experience of Assessment 1, identifying at least 3 critical incidents from the preparation and delivery of your group presentation and analysing each using a different OB concept or theory from Weeks 2–10.</p>\n<p>For each incident, you will describe its significance, evaluate the relational dynamics at play, apply relevant OB theory, and examine the ethical dimensions of your team's behaviour. You will also reflect on your growth as a team performer and propose at least two developmental activities framed as acts of responsible leadership.</p>\n<p>Your reflection should go beyond description to critically analyse both your individual and team contributions, supported by specific examples and evidence. An AI disclosure statement must be included at the end of the essay.</p>\n<p>This assessment aims to develop your ability to critically reflect on real team experiences through the lens of OB theory, deepening your understanding of how these frameworks apply to workplace dynamics.</p>\n<button class=\"collapsible__toggle\">\n<span class=\"collapsible__open link--icon icon--standard--arrow-down-1\">Read full task description</span>\n<span class=\"collapsible__close link--icon icon--standard--arrow-up-1\">Hide full task description</span>\n</button>\n</div>",
            "submission_guidelines": "<p>Submission guidelines:</p>",
            "deferral_or_extension": "<p>You may be able to <a href=\"https://my.uq.edu.au/information-and-services/manage-my-program/exams-and-assessment/applying-assessment-extension\">apply for an extension</a>.</p>",
            "late_submission": "<p>A <a href=\"https://policies.uq.edu.au/document/view-current.php?id=184\">penalty</a> of 10% of the maximum possible mark will be deducted per 24 hours from time submission is due for up to 7 days. After 7 days, you will receive a mark of 0.</p>",
            "additional_info": "<p>You may be able to <a href=\"https://my.uq.edu.au/information-and-services/manage-my-program/exams-and-assessment/applying-assessment-extension\">apply for an extension</a>.</p>"
