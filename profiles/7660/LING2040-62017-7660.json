    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "perform systematic morphological analysis on data sets from any language or groups of languages, including morphophonological analysis"
        },
        {
            "number": "LO2.",
            "description": "systematically compare and contrast word structures within and across languages"
        },
        {
            "number": "LO3.",
            "description": "identify and characterise constructions and properties that provide challenges for contemporary theories"
        },
        {
            "number": "LO4.",
            "description": "compare and contrast competing analyses of the same data or constructions"
        },
        {
            "number": "LO5.",
            "description": "identify similarities across apparently disparate languages"
        },
        {
            "number": "LO6.",
            "description": "understand the basic enterprise of linguistic typology and how it relates to other fields of linguistics"
        }
    ],
