    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Knowledge of key concepts, theories, and research methods in developmental psychology with the understanding of how psychological processes in childhood link to those observed later in life."
        },
        {
            "number": "LO2.",
            "description": "Capacity to meaningfully evaluate empirical research in developmental psychology with attention to methodological detail and awareness of relevant ethical considerations."
        },
        {
            "number": "LO3.",
            "description": "Proclivity to engage in reflective practice of psychological concepts in everyday behaviour with consideration of social-cultural influences (e.g., Indigenous perspectives in Australia)."
        },
        {
            "number": "LO4.",
            "description": "Competence in communicating effectively with people of diverse backgrounds through writing and oral discussions."
        }
    ],
