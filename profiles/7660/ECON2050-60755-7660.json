    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Demonstrate a clear understanding of basic topological concepts in Euclidean spaces."
        },
        {
            "number": "LO2.",
            "description": "Apply key concepts from the calculus of several variables such as partial and total derivatives."
        },
        {
            "number": "LO3.",
            "description": "Identify solutions of some unconstrained and constrained optimization problems."
        },
        {
            "number": "LO4.",
            "description": "Apply optimization techniques to various economic questions."
        },
        {
            "number": "LO5.",
            "description": "Develop understanding of convexity and its applications to economic problems."
        }
    ],
