    "learning_outcomes": [
        {
            "number": "LO1.",
            "description": "Apply key concepts and principles from performance psychology to analyse and improve performance in real-world settings."
        },
        {
            "number": "LO2.",
            "description": "Critically evaluate research, including research designs used in applied contexts of performance psychology."
        },
        {
            "number": "LO3.",
            "description": "Communicate evidence-based arguments and recommendations for performance improvements to a business audience."
        },
        {
            "number": "LO4.",
            "description": "Apply motivational interviewing techniques and coaching frameworks in the conduct of a coaching conversation."
        },
        {
            "number": "LO5.",
            "description": "Diagnose performance issues, and design and evaluate interventions to address them."
        },
        {
            "number": "LO6.",
            "description": "Develop analytical skills to collect, analyse and interpret psychological data, including simple between-group comparisons such as t-tests and ANOVA."
        },
        {
            "number": "LO7.",
            "description": "Work collaboratively as part of a team to use evidence-based strategies to resolve complex real-world challenges in the field of performance psychology."
        }
    ],
